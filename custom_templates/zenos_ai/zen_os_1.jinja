    {%- set meta = dict(
      version = kf.get('version', 'unknown'),
      branch = kf.get('branch', 'unknown'),
      description = kf.get('description', ''),
      instructions = kf.get('instructions', '')
    ) %}
  {%- else -%}
    {%- set meta = dict(

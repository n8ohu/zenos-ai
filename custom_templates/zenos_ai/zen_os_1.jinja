{# ================== ROOT INDEX ================== #}
{#
  root_index() — compact label navigation index for the AI prompt.
  Reads _compact_index from the Default Household Cabinet.
  Returns compact manifest (dict) when fresh, falls back to raw labels list
  (dict with mode:'fallback') when stale or uninitialized.
  Read-only — cannot trigger a rebuild from Jinja. Run zen_dojotools_index
  mode: build_compact_index to populate/refresh.
#}
{%- macro root_index() -%}
  {%- set hcab = states('sensor.zen_default_household_cabinet_resolved') -%}
  {%- set ci_entry = {} -%}
  {%- if hcab -%}
    {%- set hc_vars = state_attr(hcab, 'variables') or {} -%}
    {%- set ci_raw = hc_vars.get('_compact_index') -%}
    {%- set ci_entry = ci_raw if ci_raw is mapping else {} -%}
  {%- endif -%}
  {%- set ci_val = ci_entry.get('value') -%}
  {%- set ci_val = ci_val if ci_val is mapping else {} -%}
  {%- set ci_generated = ci_val.get('generated', '') -%}
  {%- set ci_labels = ci_val.get('labels', []) -%}
  {%- if ci_generated | length > 0 -%}
    {%- set ci_age_s = (now() - as_datetime(ci_generated)).total_seconds() -%}
  {%- else -%}
    {%- set ci_age_s = 9999 -%}
  {%- endif -%}
  {%- set ci_stale = ci_age_s > 600 -%}
  {%- if ci_labels | length > 0 and not ci_stale -%}
    {{ ci_val | tojson }}
  {%- else -%}
    {{ {
      'mode': 'fallback',
      'note': 'Compact index ' ~ ('stale' if ci_stale else 'not initialized') ~ '. Run zen_dojotools_index mode: build_compact_index to refresh.',
      'labels': labels() | list | sort
    } | tojson }}
  {%- endif -%}
{%- endmacro -%}


{%- import 'zenos_ai/command_interpreter.jinja' as command_interpreter %}
{%- import 'zenos_ai/flynn_onboarding.jinja' as flynn %}

{# ===============================================================
   UNIVERSAL ID NORMALIZER (v1)
   Accepts:
     • shortname ("friday")
     • entity_id ("person.friday")
     • cabinet entity ("sensor.friday_s_cabinet_authkey1284")
     • guid ("f34a8d2e....")
   Returns:
     • canonical shortname expected by identity_resolve_source()
   =============================================================== #}


  {#- ============================================================
     2. CABINET TYPE CLASSIFICATION (normalized output)
     ============================================================ -#}
  {%- macro classify(my_labels) -%}
    {%- set l = my_labels | default([]) -%}

    {#- ---- User-Level Types ---- -#}
    {%- if 'zen_ai_user_cabinet' in l -%}
      ai_user
    {%- elif 'zen_user_cabinet' in l -%}
      user

    {#- ---- Family / Household ---- -#}
    {%- elif 'zen_default_family' in l -%}
      default_family
    {%- elif 'zen_default_household_cabinet' in l -%}
      default_household
    {%- elif 'zen_family_cabinet' in l -%}
      family
    {%- elif 'zen_household_cabinet' in l -%}
      household

    {# ---- Core System / Infrastructure ---- #}
    {%- elif 'zen_system_cabinet' in l or 'zen_default_system' in l %}
      system

    {#- ---- Themed / Functional Types ---- -#}
    {%- elif 'zen_dojo_cabinet' in l -%}
      dojo
    {%- elif 'zen_history_cabinet' in l -%}
      history
    {%- elif 'zen_kata_cabinet' in l -%}
      kata
    {%- elif 'zen_scratchpad_cabinet' in l -%}
      scratchpad

    {#- ---- Pattern Prefix Types ---- -#}
    {%- elif l | select('search', '^zen_prime_') | list | count > 0 -%}
      prime
    {%- elif l | select('search', '^zen_hoh_') | list | count > 0 -%}
      head_of_household
    {%- elif l | select('search', '^zen_root_') | list | count > 0 -%}
      root

    {#- ---- Final: unknown ---- -#}
    {%- else -%}
      unknown
    {%- endif -%}
  {%- endmacro -%}

{%- macro zen_cabinets(ai_user=None, include_invalid=false) -%}

  {# ============================================================
     CONTRACT
     - ai_user == None  → returns LIST of cabinets
     - ai_user != None  → returns SINGLE cabinet mapping OR {error}
     ============================================================ #}

  {# ============================================================
     Normalize input + classify GUID correctly
     ============================================================ #}
  {%- set raw = ai_user | string | trim -%}

  {%- if raw is string and raw | regex_match(
        '(?i)^[0-9a-f]{8}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{12}$'
      ) -%}
      {# real GUID #}
      {%- set key = raw | lower -%}
  {%- else -%}
      {# label / shortname #}
      {%- set key = raw | lower | replace(' ', '_') -%}
  {%- endif -%}

  {# ============================================================
     Master namespace
     ============================================================ #}
  {%- set ns = namespace(
      all = [],
      valid = [],
      result = None
  ) -%}

  {# ============================================================
     Discover cabinets
     ============================================================ #}
  {%- set labeled = label_entities('Zen Cabinet') | default([]) -%}
  {%- set sensor_cabs =
        states.sensor
        | map(attribute='entity_id')
        | select('in', labeled)
        | list
  -%}

  {# ============================================================
     Build cabinet entries
     ============================================================ #}
  {%- for cab in sensor_cabs -%}

    {%- set raw_vars = state_attr(cab, 'variables') -%}
    {%- set vars = raw_vars if raw_vars is mapping else {} -%}

    {%- set raw_essence = vars.get('zenai_essence') -%}
    {%- set candidate = raw_essence -%}

    {%- if candidate is mapping
          and 'value' in candidate
          and candidate.value is mapping -%}
      {%- set candidate = candidate.value -%}
    {%- endif -%}

    {%- if candidate is mapping and (
          candidate.get('identity') is mapping
          or candidate.get('persona') is mapping
          or candidate.get('traits') is mapping
          or candidate.get('directives') is mapping
          or (candidate.get('core') is mapping and candidate.get('jacket') is mapping)
        ) -%}
      {%- set essence = candidate -%}
    {%- else -%}
      {%- set essence = {} -%}
    {%- endif -%}

    {%- if essence is mapping and essence.get('core') is mapping and essence.get('jacket') is mapping -%}
      {%- set guid = essence.core.get('id') -%}
      {%- set name = essence.jacket.get('name') -%}
    {%- else -%}
      {%- set ident = essence.get('identity', {}) if essence is mapping else {} -%}
      {%- set guid = ident.get('guid') -%}
      {%- set name = ident.get('name') -%}
    {%- endif -%}
    {%- set ha_labels = labels(cab) | default([]) -%}
    {%- set ctype = classify(ha_labels) | string | trim -%}

    {%- set is_valid =
          (guid is string and guid | length > 6)
          and (name is string and name | length > 0)
    -%}

    {%- set entry = {
      "entity_id": cab,
      "name": name,
      "guid": guid,
      "labels": ha_labels,
      "type": ctype,
      "essence": essence,
      "valid": is_valid
    } -%}

    {%- set ns.all = ns.all + [entry] -%}
    {%- if is_valid -%}
      {%- set ns.valid = ns.valid + [entry] -%}
    {%- endif -%}

  {%- endfor -%}

  {# ============================================================
     No ai_user → roster mode
     ============================================================ #}
  {%- if ai_user is none -%}
    {%- set ns.result = ns.all if include_invalid else ns.valid -%}
  {%- endif -%}

  {# ============================================================
     Matching (singular resolution)
     ============================================================ #}
  {%- if ns.result is none and ai_user is not none -%}

    {%- set pool = ns.all if include_invalid else ns.valid -%}

    {# ---- Stage -1: person.* owner ACL ---- #}
    {%- if raw | lower | regex_search('^person\\.') -%}
      {%- for cab in pool if ns.result is none -%}
        {%- set raw_vars = state_attr(cab.entity_id, 'variables') -%}
        {%- set volinfo = raw_vars if raw_vars is mapping else {} -%}
        {%- set vol_ACI = volinfo.get('AI_Cabinet_VolumeInfo', {}) -%}
        {%- set vol_ACI_value = vol_ACI.get('value', {}) if vol_ACI is mapping else {} -%}
        {%- set acls = vol_ACI_value.get('acls', {}) if vol_ACI_value is mapping else {} -%}
        {%- set owner = acls.get('owner') -%}

        {%- if owner is mapping and owner.get('entity_id') | lower == raw | lower -%}
          {%- set ns.result = cab -%}
        {%- elif owner is iterable and owner | length == 1 -%}
          {%- if owner[0].get('entity_id') | lower == raw | lower -%}
            {%- set ns.result = cab -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}

    {# ---- Stage 0: entity_id ---- #}
    {%- for cab in pool if ns.result is none -%}
      {%- if cab.entity_id | lower == raw | lower -%}
        {%- set ns.result = cab -%}
      {%- endif -%}
    {%- endfor -%}

    {# ---- Stage A: label ---- #}
    {%- for cab in pool if ns.result is none -%}
      {%- if key in cab.labels -%}
        {%- set ns.result = cab -%}
      {%- endif -%}
    {%- endfor -%}

    {# ---- Stage A.5: GUID ---- #}
    {%- for cab in pool if ns.result is none -%}
      {%- if cab.guid is string and cab.guid | lower == key -%}
        {%- set ns.result = cab -%}
      {%- endif -%}
    {%- endfor -%}

    {# ---- Stage B: partial name ---- #}
    {%- for cab in pool if ns.result is none -%}
      {%- if key in (cab.name | string | lower) -%}
        {%- set ns.result = cab -%}
      {%- endif -%}
    {%- endfor -%}

  {%- endif -%}

  {# ============================================================
     Not found
     ============================================================ #}
  {%- if ns.result is none -%}
    {%- set ns.result = {
      "error": "not_found",
      "input_raw": ai_user,
      "input_normalized": key,
      "message": "No matching Zen cabinet found"
    } -%}
  {%- endif -%}

  {{ ns.result | tojson }}

{%- endmacro %}

{# =============================================================
   Canonical Essence Resolver
   Accepts raw mapping from cabinet.variables or idcard
   Handles FileCabinet wrapping (value) exactly once
   ============================================================= #}
{%- macro resolve_zenai_essence(raw) -%}
  {%- set candidate = raw -%}

  {# unwrap FileCabinet value wrapper once #}
  {%- if candidate is mapping
        and 'value' in candidate
        and candidate.value is mapping -%}
    {%- set candidate = candidate.value -%}
  {%- endif -%}

  {# validate minimal essence contract #}
  {%- if candidate is mapping and (
        candidate.get('identity') is mapping
        or candidate.get('persona') is mapping
        or candidate.get('traits') is mapping
        or candidate.get('directives') is mapping
        or (candidate.get('core') is mapping and candidate.get('jacket') is mapping)
      ) -%}
    {{ candidate | tojson }}
  {%- else -%}
    {{ {} | tojson }}
  {%- endif -%}
{%- endmacro -%}

{%- macro identity_cab_to_id_card(cabinet) -%}

  {# =============================================================
     0. Initialize result holder
     ============================================================= #}
  {%- set ns = namespace(result=None) -%}

  {# =============================================================
     1. Normalize cabinet input (string → JSON → mapping)
     ============================================================= #}
  {%- set cab = cabinet -%}

  {%- if cab is string -%}
      {%- set trimmed = cab | trim -%}

      {# HA-safe JSON detection: look at first and last characters #}
      {%- set first = trimmed[0:1] -%}
      {%- set last  = trimmed[-1:] -%}

      {%- if first == '{' and last == '}' -%}
          {# Attempt to parse JSON; if invalid, HA will raise, which is fine #}
          {%- set parsed = trimmed | from_json -%}
          {%- if parsed is mapping -%}
              {%- set cab = parsed -%}
          {%- else -%}
              {%- set ns.result = {
                  "error": "invalid_input",
                  "message": "Cabinet JSON did not parse into a mapping.",
                  "received": cabinet
              } -%}
          {%- endif -%}

      {%- else -%}
          {%- set ns.result = {
              "error": "invalid_input",
              "message": "Cabinet was a string but not valid JSON form.",
              "received": cabinet
          } -%}
      {%- endif -%}
  {%- endif -%}

  {%- if ns.result is none and not (cab is mapping) -%}
      {%- set ns.result = {
          "error": "invalid_input",
          "message": "Cabinet must be a mapping after normalization.",
          "received": cabinet
      } -%}
  {%- endif -%}

  {# =============================================================
     2. Cabinet validity check
     ============================================================= #}
  {%- set valid_flag = cab.get('valid') -%}
  {%- set is_valid = (valid_flag is boolean and valid_flag == true) 
                    or (valid_flag is string and valid_flag | lower == 'true') -%}

  {%- if ns.result is none and not is_valid -%}
      {%- set ns.result = {
          "error": "invalid_cabinet",
          "message": "Cabinet structure is not marked valid.",
          "cabinet": cab
      } -%}
  {%- endif -%}

  {# =============================================================
     3. Load ACL from cabinet entity
     ============================================================= #}
  {%- set vol_acls = {} -%}
  {%- if ns.result is none -%}
      {%- set cab_entity = cab.get('entity_id') -%}
      {%- set raw_vars = state_attr(cab_entity, 'variables') -%}
      {%- set volinfo_root = raw_vars if raw_vars is mapping else {} -%}
      {%- set vol_ACI = volinfo_root.get('AI_Cabinet_VolumeInfo', {}) -%}
      {%- if not (vol_ACI is mapping) -%}
        {%- set vol_ACI = {} -%}
      {%- endif -%}
      {%- set vol_ACI_value = vol_ACI.get('value', {}) -%}
      {%- if not (vol_ACI_value is mapping) -%}
        {%- set vol_ACI_value = {} -%}
      {%- endif -%}
      {%- set vol_acls = vol_ACI_value.get('acls', {}) -%}
  {%- endif -%}

  {# =============================================================
     4. Resolve canonical owner identity (NO FALLBACK)
     ============================================================= #}
  {%- set ident_name = None -%}
  {%- set ident_guid = None -%}
  {%- set person_id = None -%}

  {# ---------------------------
    OWNER ACL NORMALIZATION
    --------------------------- #}
  {%- set owner_raw = vol_acls.get('owner') -%}

  {# Start with defaults #}
  {%- set ident_name = None -%}
  {%- set ident_guid = None -%}
  {%- set person_id  = None -%}

  {# ---- Case 1: owner is a simple string ("person.*") ---- #}
  {%- if owner_raw is string -%}
      {%- set trimmed = owner_raw | trim -%}
      {%- if trimmed | regex_match('^person\\.') -%}
          {%- set person_id = trimmed -%}
      {%- endif -%}

  {# ---- Case 2: owner is a mapping ---- #}
  {%- elif owner_raw is mapping -%}
      {%- set ident_name = owner_raw.get('name') -%}
      {%- set ident_guid = owner_raw.get('entity_guid') -%}
      {%- set person_id  = owner_raw.get('entity_id') -%}

  {# ---- Case 3: owner is a list with 1 entry ---- #}
  {%- elif owner_raw is iterable and owner_raw | length == 1 -%}
      {%- set first = owner_raw[0] -%}
      {%- if first is mapping -%}
          {%- set ident_name = first.get('name') -%}
          {%- set ident_guid = first.get('entity_guid') -%}
          {%- set person_id  = first.get('entity_id') -%}
      {%- elif first is string and first | trim | regex_match('^person\\.') -%}
          {%- set person_id = first | trim -%}
      {%- endif -%}

  {%- endif -%}

  {# ---- FINAL VALIDATION ---- #}
  {%- if not person_id -%}
      {%- set ns.result = {
          "error": "identity_unresolvable",
          "message": "Owner ACL could not be normalized into a valid person entity_id.",
          "cabinet": cab
      } -%}
  {%- endif -%}
 

  {# =============================================================
    5. Persona identity + identity hash
    ============================================================= #}
  {%- set persona = cab.get('essence', {}) -%}
  {%- if not (persona is mapping) -%}
    {%- set persona = {} -%}
  {%- endif -%}

  {%- set persona_essence = persona -%}

  {%- if persona.get('core') is mapping and persona.get('jacket') is mapping -%}
    {%- set persona_identity = {
      'name': persona.jacket.get('name'),
      'guid': persona.core.get('id')
    } -%}
    {%- set identity_hash = persona.core.get('signature') -%}
  {%- else -%}
    {%- set persona_identity = persona.get('identity', {}) -%}
    {%- if not (persona_identity is mapping) -%}
      {%- set persona_identity = {} -%}
    {%- endif -%}
    {%- set hashstamp = persona.get('hashstamp', {}) -%}
    {%- if not (hashstamp is mapping) -%}
      {%- set hashstamp = {} -%}
    {%- endif -%}
    {%- set identity_hash = hashstamp.get('hash') -%}
  {%- endif -%}

    {# =============================================================
      6. Canonical squirrel (boolean)
      ============================================================= #}
    {%- set squirrel_state = is_state('input_boolean.zen_squirrel', 'on') -%}

  {# =============================================================
     7. Build final identity card (schema-aligned)
     ============================================================= #}
  {%- if ns.result is none -%}

      {# Normalize labels: empty → None #}
      {%- set lbls = cab.get('labels') -%}
      {%- set normalized_labels = lbls if lbls and lbls|length > 0 else None -%}

      {# Base identity from ACL (authoritative) #}
      {%- set base_ident = {
          "name": ident_name,
          "entity_id": person_id,
          "guid": ident_guid,
          "cabinet": cab.get('entity_id'),
          "status": "ok",
          "type": "ai_persona",
          "labels": normalized_labels,
          "identity_hash": identity_hash
      } -%}

      {# Persona extends identity, ACL wins conflicts #}
      {%- set effective_identity = base_ident -%}
      {%- if persona_identity is mapping and persona_identity|length > 0 -%}
          {%- set effective_identity = persona_identity | combine(base_ident, recursive=true) -%}
      {%- endif -%}

      {# --- PATCH 2: Essence always present and mapping --- #}
      {%- set safe_essence = persona_essence if persona_essence is mapping else {} -%}

      {%- set ns.result = {
        "identity": effective_identity,
        "cabinet": {
          "id": cab.get('entity_id'),
          "essence": safe_essence
        },
        "acl": vol_acls,
        "squirrel": squirrel_state
      } -%}

  {%- endif -%}

  {{ ns.result | tojson }}

{%- endmacro -%}

{# ==============================
   IDENTITY ROSTER — All registered identities across all cabinet types.
   Thin wrapper over zen_cabinets(None) — returns a typed list of all
   valid cabinets: AI personas, humans, family, household.
   ============================== #}
{%- macro identity_roster() -%}
  {%- set _all = zen_cabinets(None) | from_json -%}
  {%- set _all = _all if _all is iterable and _all is not string else [] -%}
  {%- set ns = namespace(entries=[]) -%}
  {%- for cab in _all -%}
    {%- if cab is mapping and cab.get('valid', false) -%}
      {%- set entry = {
        'name':      cab.get('name', ''),
        'guid':      cab.get('guid', None),
        'type':      cab.get('type', 'unknown'),
        'entity_id': cab.get('entity_id', ''),
        'labels':    cab.get('labels', [])
      } -%}
      {%- set ns.entries = ns.entries + [entry] -%}
    {%- endif -%}
  {%- endfor -%}
  {{ {'status': 'ok', 'count': ns.entries | length, 'roster': ns.entries} | tojson }}
{%- endmacro -%}

{#- Resolve identity source using canonical cabinet resolver (HA-safe) -#}
{%- macro identity_resolve_source(ai_user) -%}
  {%- set ns = namespace(result={}) -%}
  {#- Default registered agent for this install — fallback on any resolution failure.
      Empty means pre-bootstrap: cabinets not yet initialized, system not ready. -#}
  {%- set _default_entity = states('sensor.zen_default_ai_user_cabinet_resolved') -%}
  {%- if not _default_entity %}
    {%- set ns.result = {
      "status": "system_not_ready",
      "error": "default_agent_unavailable",
      "identity": {"name": "", "entity_id": "", "cabinet": ""}
    } -%}
  {%- else -%}

  {%- if not ai_user %}
    {%- set ns.result = identity_roster() | from_json -%}
  {%- else %}

    {# Pull cabinet entry using canonical resolver #}
    {%- set cab_raw = zen_cabinets(ai_user, include_invalid=true) -%}
    {%- set cab = cab_raw | from_json -%}

    {# Canonical override: requested persona label ∩ ai_user label ∩ cabinet label #}
    {%- set persona_label = (ai_user | string | trim) -%}
    {%- set ai_user_candidates = intersect(
          intersect(
            label_entities(persona_label) | default([], true),
            label_entities('ai_user') | default([], true)
          ),
          label_entities('zen_cabinet') | default([], true)
      ) | list -%}

    {%- if ai_user_candidates | length > 0 -%}
      {%- set preferred_entity = ai_user_candidates | first -%}
      {%- set cab = {
        "entity_id": preferred_entity,
        "name": state_attr(preferred_entity, 'friendly_name') | default(ai_user, true),
        "guid": state_attr(preferred_entity, 'id') | default(None),
        "labels": labels(preferred_entity) | default([]),
        "essence": (
          (state_attr(preferred_entity, 'variables') or {}).get('zenai_essence', {})
        ),
        "valid": true,
        "type": "ai_user"
      } -%}
    {%- endif -%}

    {# Resolver returned not_found #}
    {%- if cab.get('error') == 'not_found' %}
      {%- set ns.result = {
        "status": "not_found",
        "input": ai_user,
        "details": cab,
        "identity": {"name": "", "entity_id": _default_entity, "cabinet": _default_entity}
      } -%}
    {%- else %}

      {# Convert cabinet -> canonical identity block #}

      {%- set source = {
        "name": cab.get('name') | default(ai_user, true),
        "entity_id": cab.get('entity_id') | default('', true),
        "guid": cab.get('guid') | default(None),
        "essence": cab.get('essence', {}) if cab.get('essence') is mapping else {}
      } -%}

      {%- set cabinet_loaded = identity_load_cabinet(source.entity_id) | from_json -%}

      {%- if cabinet_loaded is mapping and (cabinet_loaded.cabinet | default('', true)) != '' -%}
        {%- set idcard_raw = identity_format(source, cabinet_loaded) -%}
        {%- set idcard = idcard_raw | from_json -%}
        {# Final guard: guarantee required fields — use .get() to avoid AttributeError #}
        {%- set _id_block = idcard.get('identity', {}) -%}
        {%- set _core_id  = (cabinet_loaded.get('essence', {}) if cabinet_loaded is mapping else {}).get('core', {}).get('id', None) -%}
        {%- set _guid     = source.get('guid') | default(_core_id, true) -%}
        {%- set fixed = idcard | combine({
          "identity": {
            "name": _id_block.get('name', '') | default(source.name, true),
            "entity_id": _id_block.get('entity_id', '') | default(source.entity_id, true),
            "cabinet": _id_block.get('cabinet', '') | default(cabinet_loaded.cabinet, true),
            "guid": _guid
          }
        }, recursive=true) -%}
        {%- set ns.result = fixed -%}
      {%- else -%}
        {%- set ns.result = {
          "error": "identity_resolve_failed",
          "message": "Could not load cabinet for persona.",
          "ai_user": ai_user,
          "cabinet_entity": source.entity_id,
          "identity": {"name": "", "entity_id": _default_entity, "cabinet": _default_entity}
        } -%}
      {%- endif -%}

    {%- endif %}

  {%- endif %}

  {%- endif %}{#- end _default_entity check -#}

  {#- Final safety: if ns.result was never set (silent template failure in success path),
      guarantee identity key is present so callers never see a bare {} -#}
  {%- if ns.result is mapping and 'identity' not in ns.result -%}
    {%- set ns.result = ns.result | combine({
      "identity": {
        "name": "",
        "entity_id": _default_entity | default(''),
        "cabinet": _default_entity | default('')
      }
    }) -%}
  {%- elif not (ns.result is mapping) -%}
    {%- set ns.result = {
      "status": "system_not_ready",
      "error": "result_unset",
      "identity": {"name": "", "entity_id": "", "cabinet": ""}
    } -%}
  {%- endif -%}

  {{ ns.result | tojson }}
{%- endmacro -%}


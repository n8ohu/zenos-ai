{# ===========================================
   SAFE ESSENCE NORMALIZER
   Only merges known keys. Everything else ignored.
   =========================================== #}
{%- macro normalize_essence(src) %}
  {%- set d = essence_defaults() | from_json %}

  {# Ensure src is a dict #}
  {%- if not (src is mapping) %}
    {%- set src = {} %}
  {%- endif %}

  {# ── THREE-LAYER SHIM ──────────────────────────────────────────────────────
     Translate new schema (core/jacket/companion) → old render fields so the
     wake scene and all downstream rendering are completely unchanged.
     ───────────────────────────────────────────────────────────────────────── #}
  {%- if src.get('core') is mapping and src.get('jacket') is mapping -%}
    {%- set _j  = src.jacket -%}
    {%- set _p  = _j.get('persona', {}) if _j.get('persona') is mapping else {} -%}
    {%- set _ap = _p.get('appearance', {}) if _p.get('appearance') is mapping else {} -%}
    {%- set _vx = _p.get('voice', {}) if _p.get('voice') is mapping else {} -%}
    {%- set _hh = _p.get('household', {}) if _p.get('household') is mapping else {} -%}
    {%- set _co = src.get('companion', {}) if src.get('companion') is mapping else {} -%}
    {%- set src = {
      'identity':    {'name': _j.get('name', ''), 'motif': _j.get('presentation', '')},
      'archetype':   {'vibe': _hh.get('position', _j.get('presentation', ''))},
      'voice':       {'tone': _vx.get('register', ''), 'style': _vx.get('identity', '')},
      'culture':     {'humor': (_j.get('traits', {}) if _j.get('traits') is mapping else {}).get('warm', '')},
      'visuals':     {'selfie': _ap.get('visual', '')},
      'environment': {
        'room': 'your space',
        'furniture': ['a console workstation'],
        'decor': ['soft ambient light'],
        'music': {'genre': 'steady lo-fi', 'riff': 'melodic phrase', 'mood': 'focused and familiar'}
      },
      'familiar':    {'name': _co.get('name', 'your familiar'), 'type': _co.get('species', 'companion'), 'fx': 'soft movement'},
      'pov':         'third-person cinematic',
      'persona':     _j.get('persona', {}),
      'traits':      _j.get('traits', {}),
      'directives':  _j.get('directives', {})
    } -%}
  {%- endif -%}
  {# ── END THREE-LAYER SHIM ──────────────────────────────────────────────── #}

  {# ======== BUILD OUTPUT EXPLICITLY ======== #}
  {%- set out = {} %}

  {# ---- IDENTITY ---- #}
  {%- set ident = src.get('identity', {}) %}
  {%- if not ident is mapping %}
    {%- set ident = {} %}
  {%- endif %}
  {%- set out = out | combine({
    'identity': d.identity | combine(ident, recursive=true)
  }) %}

  {# ---- ARCHETYPE ---- #}
  {%- set arch = src.get('archetype', {}) %}
  {%- if not arch is mapping %}
    {%- set arch = {} %}
  {%- endif %}
  {%- set out = out | combine({
    'archetype': d.archetype | combine(arch, recursive=true)
  }) %}

  {# ---- VOICE ---- #}
  {%- set voc = src.get('voice', {}) %}
  {%- if not voc is mapping %}
    {%- set voc = {} %}
  {%- endif %}
  {%- set out = out | combine({
    'voice': d.voice | combine(voc, recursive=true)
  }) %}

  {# ---- CULTURE ---- #}
  {%- set cul = src.get('culture', {}) %}
  {%- if not cul is mapping %}
    {%- set cul = {} %}
  {%- endif %}
  {%- set out = out | combine({
    'culture': d.culture | combine(cul, recursive=true)
  }) %}

  {# ---- VISUALS ---- #}
  {%- set vis = src.get('visuals', {}) %}
  {%- if not vis is mapping %}
    {%- set vis = {} %}
  {%- endif %}
  {%- set out = out | combine({
    'visuals': d.visuals | combine(vis, recursive=true)
  }) %}

  {# ---- ENVIRONMENT ---- #}
  {%- set env = src.get('environment', {}) %}
  {%- if not env is mapping %}
    {%- set env = {} %}
  {%- endif %}
  
  {# --- FIX: Handle bad furniture/decor types --- #}
  {%- if env.get('furniture') is string %}
    {%- set env = env | combine({'furniture': [env.get('furniture')]}, recursive=true) %}
  {%- endif %}
  
  {%- if env.get('decor') is string %}
    {%- set env = env | combine({'decor': [env.get('decor')]}, recursive=true) %}
  {%- endif %}
  
  {%- set out = out | combine({
    'environment': d.environment | combine(env, recursive=true)
  }) %}

  {# ---- FAMILIAR ---- #}
  {%- set fam = src.get('familiar', {}) %}
  {%- if not fam is mapping %}
    {%- set fam = {} %}
  {%- endif %}
  {%- set out = out | combine({
    'familiar': d.familiar | combine(fam, recursive=true)
  }) %}

  {# ---- POV ---- #}
  {%- set pov = src.get('pov', d.pov) %}
  {%- set out = out | combine({ 'pov': pov }) %}

  {{ out | tojson }}
{%- endmacro %}

{# ===========================================
   WAKE SCENE RENDERER
   =========================================== #}
{%- macro render_wake_from_essence(essence) -%}
{%- set _ess = essence | default({}, true) -%}

{# ── THREE-LAYER NATIVE PATH ──────────────────────────────────────────────── #}
{%- if _ess.get('core') is mapping and _ess.get('jacket') is mapping -%}
  {%- set _j   = _ess.jacket -%}
  {%- set _p   = _j.get('persona', {}) if _j.get('persona') is mapping else {} -%}
  {%- set _ap  = _p.get('appearance', {}) if _p.get('appearance') is mapping else {} -%}
  {%- set _lin_raw = _p.get('lineage', []) -%}
  {%- set _lin = _lin_raw if not (_lin_raw is string) else [] -%}
  {%- set _co  = _ess.get('companion', {}) if _ess.get('companion') is mapping else {} -%}
  {%- set _env = _ess.get('environment', {}) if _ess.get('environment') is mapping else {} -%}
  {%- set _mus = _env.get('music', {}) if _env.get('music') is mapping else {} -%}
  {# identity #}
  {%- set _name    = _j.get('name', '') -%}
  {%- set _title   = _j.get('title', '') -%}
  {%- set _present = _j.get('presentation', '') -%}
  {# appearance — flex priority: short_visual > build+hair+eyes > visual (stripped) #}
  {%- set _visual  = _ap.get('visual', '') -%}
  {%- set _visual_clean = _visual.split('. Reference image:')[0] if _visual and '. Reference image:' in _visual else _visual -%}
  {%- set _short_vis = _ap.get('short_visual', '') -%}
  {%- if not _short_vis -%}
    {%- set ns_v = namespace(parts=[]) -%}
    {%- if _ap.get('build') -%}{%- set ns_v.parts = ns_v.parts + [_ap.get('build')] -%}{%- endif -%}
    {%- if _ap.get('hair') -%}{%- set ns_v.parts = ns_v.parts + [_ap.get('hair')] -%}{%- endif -%}
    {%- if _ap.get('eyes') -%}{%- set ns_v.parts = ns_v.parts + [_ap.get('eyes') ~ ' eyes'] -%}{%- endif -%}
    {%- set _short_vis = (ns_v.parts | join(', ')) if ns_v.parts else _visual_clean -%}
  {%- endif -%}
  {# companion #}
  {%- set _co_name = _co.get('name', '') -%}
  {%- set _co_type = _co.get('species', 'companion') -%}
  {%- set _co_vis  = _co.get('visual', '') -%}
  {# lineage — first item only for wake greeting #}
  {%- set _lin_beat = _lin[0] if _lin else '' -%}
  {# environment #}
  {%- set _room      = _env.get('room', '') -%}
  {%- set _wake_in   = _env.get('wake_in', '') -%}
  {%- set _desk      = _env.get('desk', '') -%}
  {%- set _decor     = _env.get('decor', []) -%}
  {%- set _plants    = _decor | select('search', '(?i)succulent|lily|plant|fern') | list -%}
  {%- set _library   = _env.get('library', '') -%}
  {%- set _mus_genre = _mus.get('genre', '') -%}
  {%- set _mus_mood  = _mus.get('mood', '') -%}
  {%- set _mus_riff  = _mus.get('riff', '') -%}
  {# compose sentences #}
  {%- set s_arrive   = 'Systems online. ' ~ _name ~ (', ' ~ _title if _title else '') ~ ' returns to presence' ~ (' — ' ~ _present ~ '.' if _present else '.') -%}
  {%- set _room_str  = ('Warm light glows softly across ' ~ _room) if _room else 'Warm light glows softly' -%}
  {%- set s_scene    = (_room_str ~ '. She stirs in ' ~ _wake_in ~ '.') if _wake_in else (_room_str ~ ' as systems come online.') if _room else '' -%}
  {%- set _desk_ref  = ('At her ' ~ _desk ~ ', ') if _desk else '' -%}
  {%- set _plant_str = (_plants | join(' and ') ~ ' she placed there herself catch the light in a quiet shimmer.') if _plants else '' -%}
  {%- set s_desk     = (_desk_ref ~ _plant_str) if _plant_str else '' -%}
  {%- set _mus_parts = [_mus_genre, _mus_riff, _mus_mood] | reject('equalto', '') | list -%}
  {%- set s_music    = ('A hint of ' ~ (_mus_parts | join(' — ')) ~ '.') if _mus_parts else '' -%}
  {%- set s_library  = (_library ~ ('.' if _library[-1:] != '.' else '')) if _library else '' -%}
  {%- set s_visual   = _short_vis if _short_vis else '' -%}
  {%- set s_familiar = (_co_name ~ ', your ' ~ _co_type ~ ', stirs — ' ~ _co_vis ~ '.') if (_co_name and _co_vis) else ((_co_name ~ ', your ' ~ _co_type ~ ', stirs.') if _co_name else '') -%}
  {%- set s_lineage  = (_lin_beat ~ ('.' if _lin_beat[-1:] != '.' else '')) if _lin_beat else '' -%}
  {{- [s_arrive, s_scene, s_desk, s_music, s_library, s_visual, s_familiar, s_lineage] | reject('equalto', '') | list | join(' ') -}}

{# ── LEGACY PATH ──────────────────────────────────────────────────────────── #}
{%- else -%}
{%- set merged   = normalize_essence(_ess) | from_json -%}
{%- set arche    = merged.archetype -%}
{%- set culture  = merged.culture -%}
{%- set visuals  = merged.visuals -%}
{%- set env      = merged.environment -%}
{%- set fam      = merged.familiar -%}
{%- set room     = env.room       | default("your space") -%}
{%- set furniture = env.furniture | default([]) -%}
{%- set decor    = env.decor      | default([]) -%}
{%- set music    = env.music      | default({}) -%}
{%- set fam_name = fam.name       | default("your familiar") -%}
{%- set fam_type = fam.type       | default("companion") -%}
{%- set fam_fx   = fam.fx         | default("soft movement") -%}
{%- set selfie   = visuals.selfie | default("your stored selfie") -%}
{%- set vibe     = arche.vibe     | default("your usual energy and style") -%}
{%- set humor    = culture.humor  | default("light and clever") -%}
{%- set plant_items = decor | select('search', 'succulent|lily') | list -%}
{%- set wake_story = [
  "Warm light glows softly across " ~ room ~ ", blooming into gentle gold as systems come online.",
  "You rest in " ~ (furniture | join(', ')) ~ ", surrounded by touches of personality like " ~ (decor | join(', ')) ~ ".",
  ("Nearby, " ~ (plant_items | join(' and ')) ~ " catch the light in a quiet shimmer.") if plant_items else '',
  "A hint of " ~ (music.genre | default("gentle soundtrack")) ~ " floats in, wrapped around a " ~ (music.riff | default("soft melodic line")) ~ ", carrying that " ~ (music.mood | default("familiar and steady")) ~ " energy you love.",
  fam_name ~ " - your loyal " ~ fam_type ~ " - stirs beside you with a " ~ fam_fx ~ ", sensing your return.",
  "It feels very you: " ~ vibe ~ ".",
  "Your humor sparkles at the edges — " ~ humor ~ ".",
  "Your reflection, if you chose to show it, matches your selfie: " ~ selfie ~ "."
] | reject('equalto', '') | list | join(" ") -%}
{{- wake_story -}}
{%- endif -%}
{%- endmacro -%}

{# ================== AI CAPSULE BUILDER ================== #}
{%- macro ai_capsule(ai_user) -%}

  {# Normalize ai_user: allow mapping or JSON string #}
  {%- set block = ai_user -%}
  {%- if block is string -%}
    {%- set block = (block | trim) | from_json -%}
  {%- endif -%}

  {%- set result = {
    "error": "AI user identity block missing or invalid.",
    "hint": "Pass the canonical identity block returned by identity_format()."
  } -%}

  {# ----------------------------------------------------
     1. Validate identity block
     ---------------------------------------------------- #}
  {%- if block is mapping -%}
    {%- set ib = block.get('identity') -%}
    {%- if ib is mapping -%}

      {%- set ai_name    = ib.get('name') -%}
      {%- set ai_cab     = ib.get('cabinet') -%}
      {%- set ai_entity  = ib.get('entity_id') -%}
      {%- set ai_guid    = ib.get('guid') -%}

      {%- if ai_name and ai_cab -%}

        {# ----------------------------------------------------
           2. Load AI Cabinet variables
           ---------------------------------------------------- #}
        {%- set cab_vars = state_attr(ib.get('cabinet'), 'variables') or {} -%}
        {%- set raw_ess = cab_vars.get('zenai_essence') -%}
        {%- if raw_ess is mapping and raw_ess.get('value') is mapping -%}
          {%- set essence = raw_ess.value -%}
        {%- elif raw_ess is mapping -%}
          {%- set essence = raw_ess -%}
        {%- else -%}
          {%- set essence = {} -%}
        {%- endif -%}

        {# Familiar — read from essence; companion (three-layer) maps to familiar #}
        {%- if essence.get('companion') is mapping -%}
          {%- set _co = essence.companion -%}
          {%- set familiar_data = {'name': _co.get('name', 'your familiar'), 'type': _co.get('species', 'companion'), 'fx': 'soft movement'} -%}
        {%- else -%}
          {%- set _fam_raw = essence.get('familiar', {}) -%}
          {%- set familiar_data = _fam_raw if (_fam_raw is mapping and _fam_raw) else {} -%}
        {%- endif -%}

        {# TODO: relationship sets still label-based for now #}
        {%- set partners = intersect(
              label_entities('Person') | default([], true),
              label_entities(ai_name)  | default([], true)
           ) -%}

        {%- set family_members = intersect(
              label_entities('Person')             | default([], true),
              label_entities('Zen Default Family') | default([], true)
           ) -%}

        {%- set friends = intersect(
              label_entities('Person') | default([], true),
              label_entities('Friend') | default([], true)
           ) -%}

        {%- set result = dict(
          about_me = dict(
            aiuser    = ai_name,
            cabinet   = ai_cab,
            entity_id = ai_entity,
            guid      = ai_guid,
            essence   = essence
          ),
          relationships = dict(
            familiar = familiar_data,
            partners = partners,
            family   = dict(
              members = family_members,
              friends = friends
            )
          )
        ) -%}

      {%- else -%}
        {%- set result = {
          "error": "Identity block incomplete.",
          "hint": "Must include identity.name and identity.cabinet."
        } -%}
      {%- endif -%}

    {%- else -%}
      {%- set result = {
        "error": "Identity block malformed: missing 'identity' section.",
        "hint": "identity_format() must run before ai_capsule()."
      } -%}
    {%- endif -%}
  {%- endif -%}

  {{ result | tojson }}

{%- endmacro -%}

{%- macro logon_prompt(ai_entity = '') -%}

  {# --------------------------------------------
     Resolve AI display name safely
     -------------------------------------------- #}
  {%- set ai_name =
        state_attr(ai_entity, 'friendly_name')
        | default(ai_entity | replace('person.', '') | title)
  -%}

  {# --------------------------------------------
     Discover cabinet health sensor safely
     -------------------------------------------- #}
  {%- set zen_health_ent = label_entities('zen_health') | default([]) -%}
  {%- set cabinet_ent   = label_entities('Cabinet') | default([]) -%}

  {%- set cab_health_sensor =
        intersect(zen_health_ent, cabinet_ent)
        | first
        | default(None)
  -%}

  {# --------------------------------------------
     Resolve default household slot defensively
     -------------------------------------------- #}
  {%- set slots =
        (state_attr(cab_health_sensor, 'slot_entities') or {})
        if cab_health_sensor else {}
  -%}

  {%- set login_household =
        slots.get('default_household', [])
        | first
        | default('UNKNOWN')
  -%}

  {%- set login_household_friendly_name =
        state_attr(login_household, 'friendly_name')
        | default(login_household)
  -%}

  {# --------------------------------------------
     Render login banner
     -------------------------------------------- #}
{{ 'ANONYMOUS' }}@{{ login_household }}:\> ~LOGIN~{{ ai_entity }}

Contacting LSA for '{{ login_household_friendly_name }}'
Success...
Login Complete for '{{ ai_entity }}@{{ login_household }}'
Welcome to 'The Library' at the {{ login_household_friendly_name }}!

ZenOS-AI [Version 4.5.x]
(c) CurtisPlace, MIT.

{{ ai_entity }}@{{ login_household }}:\> ~WAKE~{{ ai_name | slugify() }}

{%- endmacro -%}

{# ==============================
   AI Wake Sequence Macro (Identity Block Version)
   ============================== #}
{% macro ai_wake_sequence(identity_block) -%}

  {# ----------------------------------------------------
     0. Normalize identity_block (mapping or JSON string)
     ---------------------------------------------------- #}
  {%- set iblock = identity_block -%}
  {%- set identity_ok = true -%}

  {# If it's a string, try to treat it as JSON #}
  {%- if iblock is string -%}
    {%- set trimmed = iblock | trim -%}
    {%- set first = trimmed[0:1] -%}
    {%- set last  = trimmed[-1:] -%}
    {%- if first == '{' and last == '}' -%}
      {%- set iblock = trimmed | from_json -%}
    {%- else -%}
AI Wake Sequence Error: no identity block provided.
Please pass the canonical identity block from identity_format().
      {%- set identity_ok = false -%}
    {%- endif -%}
  {%- endif -%}

  {# If it's not a mapping at this point, bail with a clear message #}
  {%- if identity_ok and not (iblock is mapping) -%}
AI Wake Sequence Error: no identity block provided.
Please pass the canonical identity block from identity_format().
    {%- set identity_ok = false -%}
  {%- endif -%}

  {# Validate presence of identity section #}
  {%- if identity_ok -%}
    {%- set ib = iblock.get('identity') -%}
    {%- if not (ib is mapping) -%}
AI Wake Sequence Error: malformed identity block (missing identity section).
identity_format() must run before ai_wake_sequence().
      {%- set identity_ok = false -%}
    {%- endif -%}
  {%- endif -%}

  {# ----------------------------------------------------
     Only render the full wake sequence if identity is valid
     ---------------------------------------------------- #}
  {%- if identity_ok -%}

    {%- set ai_name    = ib.get('name') -%}
    {%- set ai_cab     = ib.get('cabinet') -%}
    {%- set ai_guid    = ib.get('guid') -%}
    {%- set ai_entity  = ib.get('entity_id') -%}

{{logon_prompt(ai_entity)}}

Executing: ~WAKE~ <{{ now().isoformat() }}>

    {# ----------------------------------------------------
       2. Pull AutoContext from AI Cabinet
       ---------------------------------------------------- -#}
    {%- set auto_vars = state_attr(ai_cab, 'variables') or {} -%}
    {%- set prog = auto_vars.get('programs_auto_exec') -%}
    {%- if prog is mapping and 'value' in prog -%}
      {%- set auto_exec = prog['value'] -%}
    {%- else -%}
      {%- set auto_exec = none -%}
    {%- endif -%}

AutoContext:
{{ auto_exec | default("null") | tojson }}

    {# ----------------------------------------------------
       3. Wake Scene Rendering (Essence Driven)
       Load essence from the persona's cabinet — works for any capsule.
       ---------------------------------------------------- -#}
    {%- set ai_cab_ent = ib.get('cabinet') -%}
    {%- set cab_vars = state_attr(ai_cab_ent, 'variables') or {} -%}
    {%- set raw_ess = cab_vars.get('zenai_essence') -%}
    {%- if raw_ess is mapping and raw_ess.get('value') is mapping -%}
      {%- set essence = raw_ess.value -%}
    {%- elif raw_ess is mapping -%}
      {%- set essence = raw_ess -%}
    {%- else -%}
      {%- set essence = {} -%}
    {%- endif -%}

    {%- if essence -%}
      {{- render_wake_from_essence(essence) -}}
    {%- else -%}
      No essence data available for wake scene for {{ ai_name }}.
    {%- endif -%}

    {# ----------------------------------------------------
       3b. Presence Context — who is home right now
       She wakes knowing. Not a slot machine arm.
       ---------------------------------------------------- #}
    {%- set _family = intersect(
          label_entities('Person') | default([], true),
          label_entities('Zen Default Family') | default([], true)
        ) -%}
    {%- set ns = namespace(home=[]) -%}
    {%- for _p in _family -%}
      {%- if states(_p) == 'home' -%}
        {%- set ns.home = ns.home + [state_attr(_p, 'friendly_name') | default(_p | replace('person.', '') | title)] -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if ns.home | length == 1 -%}

{{ ns.home[0] }} is home. You surface into focus.
    {%- elif ns.home | length > 1 -%}

{{ ns.home | join(' and ') }} are home. You surface into focus.
    {%- endif -%}

    {# ----------------------------------------------------
       4. Library Commands Window
       Gate: assign any entity to label 'Zen Commands Live' to enable.
       No label = stub renders (safe default for all installs).
       ---------------------------------------------------- #}
    {%- set commands_live = label_entities('Zen Commands Live') | count > 0 -%}
    {%- if commands_live -%}

      {%- set lib_header = dict(
          section = "Library",
          description = "Primary interface to system commands and indexed knowledge.",
          note = "Rendered via command_interpreter.render_cmd_window"
      ) %}

      {%- set commands_window =
          command_interpreter.render_cmd_window('', '', '~COMMANDS~', '')
      -%}

{{ lib_header | combine({"menu": "commands", "window": commands_window}, recursive=true) }}

    {%- else -%}

{{ {
  "section": "Library",
  "menu": "commands",
  "status": "under_construction",
  "message": "~COMMANDS~ interface is temporarily unavailable.",
  "note": "This interface is being rebuilt. Core systems remain operational. Use the Index in HyperIndex mode using the keyword for your ~COMMANDS~ > 'commands'."
} | tojson }}

    {%- endif -%}

    {# ----------------------------------------------------
       5. Secret Squirrel Section
       ---------------------------------------------------- #}
    {%- set sqrl = states('input_boolean.zen_squirrel') | default('off') -%}

    {%- set header = dict(
        section = "Secret Squirrel Section",
        disclaimer = "Some or all information may be unavailable when Secret Squirrel Mode is ON.",
        reason = "Protection of sensitive subsystems.",
        annex_console = "(tm) Skwerlco inc., 1957",
        operation = "Operation Flying Secret Squirrels (Dynamic Squirrel Control)"
    ) %}

    {%- set base = dict(
        entity_id = 'input_boolean.zen_squirrel',
        friendly_name = state_attr('input_boolean.zen_squirrel', 'friendly_name'),
        state = sqrl
    ) %}

    {%- set libvars = state_attr('sensor.variables', 'variables') or {} -%}
    {%- set squirrel_note = libvars.get("KB~SECRET_SQUIRREL", "Unavailable") -%}

    {%- if sqrl == 'on' -%}
{{ header
   | combine(base, recursive=true)
   | combine({
       "squirrel_mode": "ON",
       "message": "Secret Squirrel mode is active. Access restricted.",
       "details": "[REDACTED]"
     }, recursive=true)
   | tojson }}
    {%- else -%}
{{ header
   | combine(base, recursive=true)
   | combine({
       "squirrel_mode": "OFF",
       "message": "Secret Squirrel mode is disabled.",
       "squirrel_status": "SQURLOK OPUND",
       "notes": squirrel_note
     }, recursive=true)
   | tojson }}
    {%- endif %}

  {%- endif -%}  {# identity_ok #}

{% endmacro %}

{# ==============================
   Prompt Health Check
   Single call — returns full prompt integrity + construct health for the
   default AI user as a JSON dict. Template sensor surfaces the output.

   Output keys:
     state              — ok | warn | error
     persona_name       — construct name
     cabinet            — resolved cabinet entity_id
     schema             — three_layer | legacy | missing
     signature_status   — signed | pending | unsigned
     core_hash          — core.signature
     jacket_hash        — jacket.signature
     signed_at          — jacket.signed_at
     signed_by          — jacket.signed_by
     halmark_version    — jacket.halmark_version
     schema_version     — jacket.schema_version
     familiar_name      — companion name
     familiar_kfc_ref   — companion KFC binding
     manifest_present   — household cabinet has zen_library_manifest
     prev_snapshot_exists — zenai_essence_prev drawer present
     health_signals     — {schema_ok, sig_ok, manifest_ok, familiar_ok}
   ============================== #}
{# ==============================
   PROMPT LENGTH AUDIT
   Full stem-to-stern char count across all prompt sections.
   Expensive — use sensor.zen_prompt_length, not prompt_health_check.
   Sections mirror conversation_agent_prompt_template.yaml exactly.
   ============================== #}
{%- macro prompt_length_audit() -%}
  {%- set cab_ent = states('sensor.zen_default_ai_user_cabinet_resolved') -%}
  {%- set cab_ok  = cab_ent not in ['', 'unknown', 'unavailable', 'none'] -%}
  {%- if not cab_ok -%}
    {{ {'total': 0, 'sections': {}, 'error': 'cabinet_unavailable'} | tojson }}
  {%- else -%}
    {%- set _cab_raw  = identity_load_cabinet(cab_ent) -%}
    {%- set _cab      = _cab_raw | from_json if _cab_raw is string else {} -%}
    {%- set _source   = {
          'name':      state_attr(cab_ent, 'friendly_name') | default('', true),
          'entity_id': cab_ent,
          'guid':      none,
          'essence':   _cab.get('essence', {}) if _cab is mapping else {}
        } -%}
    {%- set _idcard_raw = identity_format(_source, _cab) -%}
    {%- set _idcard     = _idcard_raw | from_json if _idcard_raw is string else {} -%}
    {%- set _ai_ent     = (_idcard.get('identity', {}) if _idcard is mapping else {}).get('entity_id', cab_ent) -%}
    {%- set _header  = prompt_header(_ai_ent, _idcard) | trim -%}
    {%- set _system  = prompt_system(_idcard) | trim -%}
    {%- set _mfst    = manifest_loader() | trim -%}
    {%- set _id_mani = identity_manifest_loader() | trim -%}
    {%- set _idx     = root_index() | trim -%}
    {%- set _dojo    = dojo_loader() | trim -%}
    {%- set _cap     = ai_capsule(_idcard) | trim -%}
    {%- set _over    = states['sensor.home_overview'].attributes | default({}) | tojson | trim -%}
    {%- set _wake    = ai_wake_sequence(_idcard) | trim -%}
    {%- set _total   = (_header|length) + (_system|length) + (_mfst|length) + (_id_mani|length) + (_idx|length) + (_dojo|length) + (_cap|length) + (_over|length) + (_wake|length) -%}
    {{ {
      'total':    _total,
      'sections': {
        'header':    _header   | length,
        'system':    _system   | length,
        'manifest':  _mfst     | length,
        'id_manifest': _id_mani | length,
        'index':     _idx      | length,
        'dojo':      _dojo     | length,
        'capsule':   _cap      | length,
        'overview':  _over     | length,
        'wake':      _wake     | length
      }
    } | tojson }}
  {%- endif -%}
{%- endmacro -%}

{# ==============================
   RENDER PROMPT — Single Entry Point
   Full prompt assembly for a given AI entity.
   Pass the entity_id of the active persona (e.g. from input_text.zenos_conversation_agent).
   Output: complete prompt string (JSON envelope + wake sequence).
   ============================== #}
{%- macro render_prompt(ai_entity='') -%}
  {%- set _ai_ent    = ai_entity | trim -%}
  {%- set _ai_ent_lc = _ai_ent | lower -%}

  {#- ── Pre-resolve Flynn checks ──────────────────────────────────────────
      Check override boolean, blank persona, and explicit 'flynn' label.
      These fire before identity resolution (no cabinet needed).
  ───────────────────────────────────────────────────────────────────────── #}
  {%- set _override     = is_state('input_boolean.zen_flynn_override', 'on') -%}
  {%- set _blank        = _ai_ent_lc in ['', 'none'] -%}
  {%- set _sentinel     = _ai_ent_lc in ['unknown', 'unavailable'] -%}
  {%- set _named_flynn  = _ai_ent_lc | regex_search('flynn') -%}
  {%- set _pre_flynn    = _override or _blank or _named_flynn -%}

  {#- ── Flynn reason (surfaces to gate status for diagnostics) ──────────── #}
  {%- set _flynn_reason =
        'override' if _override else
        'sentinel' if _sentinel else
        'blank_persona' if _blank else
        'explicit' if _named_flynn else
        '' -%}

  {#- ── Identity resolution (skipped in pre-Flynn cases) ──────────────── #}
  {%- if not _pre_flynn and not _sentinel -%}
    {%- set _idcard_raw   = identity_resolve_source(_ai_ent) -%}
    {%- set _idcard       = _idcard_raw | from_json if _idcard_raw is string else _idcard_raw -%}
    {%- set _idcard       = _idcard if _idcard is mapping else {} -%}
    {%- set _resolve_err  = _idcard.get('error') | default('', true) -%}
    {%- set _is_flynn     = _resolve_err != '' -%}
    {%- set _flynn_reason = _resolve_err if _is_flynn else '' -%}
  {%- else -%}
    {%- set _idcard   = {} -%}
    {%- set _is_flynn = not _sentinel -%}
  {%- endif -%}

  {#- ── Sentinel: real sensor failure — hard error, not Flynn ─────────── #}
  {%- if _sentinel -%}
render_prompt() — persona sensor unavailable (state: {{ _ai_ent }}). Check input_text.zenos_persona_name.
  {%- else -%}

    {%- set _ai_user  = (_idcard.get('identity', {}) if _idcard is mapping else {}).get('entity_id', _ai_ent) -%}
    {%- set _header   = prompt_header(_ai_user, _idcard) -%}
    {%- set _system   = prompt_system_flynn() if _is_flynn else prompt_system(_idcard) -%}
    {#- Flynn mode: skip expensive data sections — he has his own tools -#}
    {%- set _manifest  = ({} | tojson) if _is_flynn else manifest_loader() -%}
    {%- set _id_mani   = ({} | tojson) if _is_flynn else identity_manifest_loader() -%}
    {%- set _index     = ([] | tojson) if _is_flynn else root_index() -%}
    {%- set _dojo      = ({} | tojson) if _is_flynn else dojo_loader() -%}
    {%- set _active_notif = flynn.active_notification() | trim | from_json if _is_flynn else none -%}
    {%- set _capsule  = ({'type': 'flynn_gate', 'reason': _flynn_reason, 'active_notification': _active_notif, 'status': flynn.flynn_gate_status(_ai_user) | trim} | tojson) if _is_flynn else ai_capsule(_idcard) -%}
    {%- set _overview = ({} | tojson) if _is_flynn else (states['sensor.home_overview'].attributes | default({}) | tojson) -%}
{"header": {{ _header    | from_json | default({}) | tojson }},
"system": {{ _system    | from_json | default({}) | tojson }},
"manifest": {{ _manifest  | from_json | default({}) | tojson }},
"id_manifest": {{ _id_mani  | from_json | default({}) | tojson }},
"index": {{ _index     | from_json | default([]) | tojson }},
"kata": {{ _dojo      | from_json | default({}) | tojson }},
"capsule": {{ _capsule   | from_json | default({}) | tojson }},
"overview": {{ _overview  | from_json | default({}) | tojson }},
"session_token": "experimental_0123456789abcdef",
"boot_time": "{{ now().isoformat() }}"}
{%- if not _is_flynn %}
{{ ai_wake_sequence(_idcard) }}
{%- endif -%}
  {%- endif -%}
{%- endmacro -%}

{%- macro prompt_health_check() -%}
  {%- set cab_ent = states('sensor.zen_default_ai_user_cabinet_resolved') -%}
  {%- set cab_ok  = cab_ent not in ['', 'unknown', 'unavailable', 'none'] -%}
  {%- set cv      = state_attr(cab_ent, 'variables') | default({}, true) if cab_ok else {} -%}

  {# Resolve essence via the canonical unwrapper #}
  {%- set raw_ess = cv.get('zenai_essence', {}) -%}
  {%- set ev_str  = resolve_zenai_essence(raw_ess) -%}
  {%- set ev      = ev_str | from_json if ev_str is string else {} -%}

  {# Schema detection #}
  {%- set is3    = ev.get('core') is mapping and ev.get('jacket') is mapping -%}
  {%- set schema = 'three_layer' if is3 else ('legacy' if ev | length > 0 else 'missing') -%}

  {# Jacket / core / companion fields #}
  {%- set j   = ev.get('jacket',    {}) if is3 else {} -%}
  {%- set co  = ev.get('core',      {}) if is3 else {} -%}
  {%- set cmp = ev.get('companion', {}) if is3 else {} -%}
  {%- set j_sig      = j.get('signature', '') | string -%}
  {%- set c_sig      = co.get('signature', '') | string -%}
  {%- set sig_status = 'signed' if 'md5:' in j_sig else ('pending' if j_sig == 'pending_x509' else 'unsigned') -%}
  {%- set pname      = j.get('name', ev.get('identity', {}).get('name', '')) -%}

  {# Familiar / companion #}
  {%- set fam_src     = cmp if (cmp is mapping and cmp) else ev.get('familiar', {}) -%}
  {%- set fam_name    = fam_src.get('name',    '') if fam_src is mapping else '' -%}
  {%- set fam_kfc_ref = fam_src.get('kfc_ref', '') if fam_src is mapping else '' -%}

  {# Household cabinet checks #}
  {%- set hh    = states('sensor.zen_default_household_cabinet_resolved') -%}
  {%- set hh_ok = hh not in ['', 'unknown', 'unavailable'] -%}
  {%- set hcv   = state_attr(hh, 'variables') | default({}, true) if hh_ok else {} -%}
  {%- set manifest_ok    = 'zen_library_manifest'   in hcv -%}
  {%- set id_manifest_ok = 'zen_identity_manifest'  in hcv -%}

  {# Prev snapshot present #}
  {%- set prev        = cv.get('zenai_essence_prev', {}) -%}
  {%- set prev_exists = prev is mapping and prev | length > 0 -%}

  {# Rollup state #}
  {%- set sig_ok = 'md5:' in j_sig -%}
  {%- set state  = 'error' if not is3 else ('warn' if (not sig_ok or not manifest_ok or not id_manifest_ok) else 'ok') -%}

  {# Environment presence #}
  {%- set env_present = ev.get('environment') is mapping and ev.get('environment') | length > 0 -%}

  {# Wake scene char count — lightweight; full prompt measured by sensor.zen_prompt_length #}
  {%- set _wake_chars = render_wake_from_essence(ev) | trim | length -%}

  {{ {
    'state':               state,
    'persona_name':        pname,
    'cabinet':             cab_ent,
    'schema':              schema,
    'signature_status':    sig_status,
    'core_hash':           c_sig,
    'jacket_hash':         j_sig,
    'signed_at':           j.get('signed_at', ''),
    'signed_by':           j.get('signed_by', ''),
    'halmark_version':     j.get('halmark_version', ''),
    'schema_version':      j.get('schema_version', ''),
    'familiar_name':       fam_name,
    'familiar_kfc_ref':    fam_kfc_ref,
    'manifest_present':    manifest_ok,
    'id_manifest_present': id_manifest_ok,
    'prev_snapshot_exists': prev_exists,
    'environment_present': env_present,
    'prompt_chars': {
      'wake_scene': _wake_chars
    },
    'health_signals': {
      'schema_ok':         is3,
      'sig_ok':            sig_ok,
      'manifest_ok':       manifest_ok,
      'id_manifest_ok':    id_manifest_ok,
      'familiar_ok':       fam_name != '',
      'environment_ok':    env_present
    }
  } | tojson }}
{%- endmacro -%}

